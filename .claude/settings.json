{
  "statusLine": {
    "type": "command",
    "command": "sh /home/kamil/.claude/statusline-command.sh"
  },
  "model": "opus[1m]",
  "theme": "dark",
  "attribution": {
    "pr": ""
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(standardrb *)",
      "Bash(standardrb)",
      "Bash(bundle exec rspec *)",
      "Bash(bundle exec parallel_rspec *)",
      "Bash(bundle exec standardrb *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(rg)",
      "Bash(echo *)",
      "Bash(echo)",
      "Bash(head *)",
      "Bash(head)",
      "Bash(tail *)",
      "Bash(cat *)",
      "Bash(sed *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(cd *)",
      "Bash(jq *)",
      "Bash(base64 *)",
      "Bash(command -v *)",
      "Bash(tmux show-options *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git fetch *)",
      "Bash(git --no-pager diff *)",
      "Bash(git --no-pager log *)",
      "Bash(git --no-pager show *)",
      "Bash(git show *)",
      "Bash(git diff *)",
      "Bash(git cat-file *)",
      "Bash(git ls-tree *)",
      "Bash(git check-ignore *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git stash list)",
      "Bash(git stash list *)",
      "Bash(gh pr checkout *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr status)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh issue status)",
      "Bash(gh repo view *)",
      "Bash(gh run view *)",
      "Bash(gh run list *)",
      "Bash(gh workflow view *)",
      "Bash(gh workflow list *)",
      "Bash(gh release view *)",
      "Bash(gh release list *)",
      "Bash(gh label list *)",
      "Bash(gh search *)",
      "Bash(gh api --method GET *)",
      "Bash(gh api -X GET *)",
      "Bash(gh status)",
      "Read(//home/kamil/.claude/**)",
      "Read(//home/kamil/Misc/dotfiles/**)",
      "Edit(tmp/**)",
      "Write(tmp/**)",
      "Edit(**/tmp/**)",
      "Write(**/tmp/**)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "msg=\"$(jq -r '.message // \"Claude needs your input\"')\"; notify-send \"🤖 Claude Code\" \"$msg\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh /home/kamil/.claude/generate-topic.sh"
          }
        ]
      }
    ]
  }
}
