{
  "statusLine": {
    "type": "command",
    "command": "sh /home/kamil/.claude/statusline-command.sh"
  },
  "model": "opus[1m]",
  "theme": "dark",
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(standardrb *)",
      "Bash(standardrb)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "msg=\"$(jq -r '.message // \"Claude needs your input\"')\"; notify-send \"🤖 Claude Code\" \"$msg\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh /home/kamil/.claude/generate-topic.sh"
          }
        ]
      }
    ]
  }
}
