{
  "statusLine": {
    "type": "command",
    "command": "sh /home/kamil/.claude/statusline-command.sh"
  },
  "model": "opus[1m]",
  "theme": "dark",
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(standardrb *)",
      "Bash(standardrb)",
      "Bash(bundle exec rspec *)",
      "Bash(bundle exec parallel_rspec *)",
      "Bash(bundle exec standardrb *)",
      "Bash(grep *)",
      "Bash(echo *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(cat *)",
      "Bash(jq *)",
      "Bash(command -v *)",
      "Bash(tmux show-options *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git fetch *)",
      "Bash(git --no-pager diff *)",
      "Bash(git --no-pager log *)",
      "Bash(git --no-pager show *)",
      "Read(//home/kamil/.claude/**)",
      "Read(//home/kamil/Misc/dotfiles/**)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "msg=\"$(jq -r '.message // \"Claude needs your input\"')\"; notify-send \"🤖 Claude Code\" \"$msg\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh /home/kamil/.claude/generate-topic.sh"
          }
        ]
      }
    ]
  }
}
